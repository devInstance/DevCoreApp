@page "/admin/webhook-deliveries"
@page "/admin/webhook-deliveries/{SubscriptionId}"
@attribute [Authorize(Policy = "Admin.Webhooks.View")]

<PageTitle>Webhook Deliveries</PageTitle>

<div class="row mb-3">
    <div class="col">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="admin/webhooks">Webhooks</a></li>
                <li class="breadcrumb-item active">Delivery Log</li>
            </ol>
        </nav>
    </div>
</div>

@if (Host.IsError)
{
    <div class="alert alert-danger" role="alert">
        @Host.ErrorMessage
    </div>
}

<HDataGrid TItem="DevInstance.DevCoreApp.Shared.Model.Webhooks.WebhookDeliveryItem"
           Data="DeliveryList"
           Columns="Columns"
           IsLoading="Host.InProgress"
           OnSort="OnSortAsync"
           OnPageChanged="OnPageChangedAsync"
           OnColumnsChanged="OnColumnsChanged"
           OnRowClick="OnRowClick">
    <ColumnTemplates>
        <HColumnTemplate TItem="DevInstance.DevCoreApp.Shared.Model.Webhooks.WebhookDeliveryItem" Field="status" Context="del">
            @switch (del.Status)
            {
                case DevInstance.DevCoreApp.Shared.Model.Webhooks.WebhookDeliveryStatus.Delivered:
                    <span class="badge bg-success">Delivered</span>
                    break;
                case DevInstance.DevCoreApp.Shared.Model.Webhooks.WebhookDeliveryStatus.Failed:
                    <span class="badge bg-danger">Failed</span>
                    break;
                case DevInstance.DevCoreApp.Shared.Model.Webhooks.WebhookDeliveryStatus.Pending:
                    <span class="badge bg-warning">Pending</span>
                    break;
            }
        </HColumnTemplate>
        <HColumnTemplate TItem="DevInstance.DevCoreApp.Shared.Model.Webhooks.WebhookDeliveryItem" Field="responsecode" Context="del">
            @if (del.ResponseStatusCode.HasValue)
            {
                <span class="@(del.ResponseStatusCode < 300 ? "text-success" : "text-danger")">@del.ResponseStatusCode</span>
            }
            else
            {
                <span class="text-muted">&mdash;</span>
            }
        </HColumnTemplate>
        <HColumnTemplate TItem="DevInstance.DevCoreApp.Shared.Model.Webhooks.WebhookDeliveryItem" Field="attempts" Context="del">
            @del.AttemptCount
            @if (del.NextRetryAt.HasValue)
            {
                <small class="text-muted ms-1">(retry @del.NextRetryAt.Value.ToString("HH:mm"))</small>
            }
        </HColumnTemplate>
    </ColumnTemplates>
    <EmptyContent>
        <p>No webhook deliveries found.</p>
    </EmptyContent>
</HDataGrid>

<GridSettings Columns="Columns" OnSave="OnSave" PageSize="pageCount" TItem="DevInstance.DevCoreApp.Shared.Model.Webhooks.WebhookDeliveryItem" />

@* ---------- Detail Modal ---------- *@
@if (SelectedDelivery != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delivery Details</h5>
                    <button type="button" class="btn-close" @onclick="CloseDetail"></button>
                </div>
                <div class="modal-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-3">Event Type</dt>
                        <dd class="col-sm-9">@SelectedDelivery.EventType</dd>

                        <dt class="col-sm-3">URL</dt>
                        <dd class="col-sm-9"><code>@SelectedDelivery.Url</code></dd>

                        <dt class="col-sm-3">Status</dt>
                        <dd class="col-sm-9">@SelectedDelivery.Status</dd>

                        <dt class="col-sm-3">HTTP Status</dt>
                        <dd class="col-sm-9">@(SelectedDelivery.ResponseStatusCode?.ToString() ?? "N/A")</dd>

                        <dt class="col-sm-3">Attempts</dt>
                        <dd class="col-sm-9">@SelectedDelivery.AttemptCount</dd>

                        <dt class="col-sm-3">Created</dt>
                        <dd class="col-sm-9">@SelectedDelivery.CreateDate.ToString("yyyy-MM-dd HH:mm:ss")</dd>
                    </dl>

                    <h6 class="mt-3">Request Payload</h6>
                    <pre class="bg-light p-2 rounded" style="max-height:200px;overflow:auto;"><code>@SelectedDelivery.Payload</code></pre>

                    @if (!string.IsNullOrEmpty(SelectedDelivery.ResponseBody))
                    {
                        <h6 class="mt-3">Response Body</h6>
                        <pre class="bg-light p-2 rounded" style="max-height:200px;overflow:auto;"><code>@SelectedDelivery.ResponseBody</code></pre>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseDetail">Close</button>
                </div>
            </div>
        </div>
    </div>
}
