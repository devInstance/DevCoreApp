@page "/admin/settings"
@attribute [Authorize(Policy = "Admin.Settings.Edit")]

<PageTitle>Settings</PageTitle>

<div class="row mb-3">
    <div class="col col-md-6 col-lg-4 d-flex">
        <input class="form-control" placeholder="Search settings..." @bind="SearchTerm" @bind:event="oninput" disabled="@Host.InProgress" />
        <button class="btn btn-primary ms-2" @onclick="OnSearch" disabled="@Host.InProgress">
            <i class="bi bi-search"></i>
        </button>
    </div>
    <div class="col col-md-6 col-lg-8">
        <div class="d-flex align-items-center justify-content-end gap-2">
            <div class="btn-group" role="group">
                <button type="button" class="btn @(CurrentScope == ScopeSystem ? "btn-primary" : "btn-outline-primary")" @onclick="OnScopeSystem" disabled="@Host.InProgress">
                    <i class="bi bi-globe me-1"></i>System
                </button>
                <button type="button" class="btn @(CurrentScope == ScopeTenant ? "btn-primary" : "btn-outline-primary")" @onclick="OnScopeTenant" disabled="@Host.InProgress">
                    <i class="bi bi-building me-1"></i>Tenant
                </button>
                <button type="button" class="btn @(CurrentScope == ScopeOrganization ? "btn-primary" : "btn-outline-primary")" @onclick="OnScopeOrganization" disabled="@Host.InProgress">
                    <i class="bi bi-diagram-3 me-1"></i>Organization
                </button>
            </div>
            <button class="btn btn-success" @onclick="OnAddNew" disabled="@Host.InProgress">
                <i class="bi bi-plus-lg me-1"></i>New Setting
            </button>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(SearchTerm) && Settings != null)
{
    <div class="alert alert-light">
        Searching for <strong>@SearchTerm</strong>
        <button type="button" class="btn-close ms-2" @onclick="OnClearSearch"></button>
    </div>
}

@if (ShowAddForm)
{
    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="mb-0">
                <i class="bi bi-plus-circle me-1"></i> New Setting
                <span class="badge bg-primary ms-1">@CurrentScope</span>
            </h6>
            <button class="btn-close" @onclick="OnCancelAdd"></button>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Category</label>
                    <input class="form-control" @bind="NewSetting.Category" placeholder="e.g. General" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Key</label>
                    <input class="form-control" @bind="NewSetting.Key" placeholder="e.g. MaxRetries" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Value Type</label>
                    <select class="form-select" @bind="NewSetting.ValueType">
                        <option value="string">String</option>
                        <option value="int">Integer</option>
                        <option value="bool">Boolean</option>
                        <option value="json">JSON</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Options</label>
                    <div class="form-check form-switch mt-2">
                        <input class="form-check-input" type="checkbox" @bind="NewSetting.IsSensitive" id="newSettingSensitive" />
                        <label class="form-check-label" for="newSettingSensitive">Sensitive value</label>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Value</label>
                    @if (NewSetting.ValueType == "bool")
                    {
                        <div class="form-check form-switch mt-2">
                            <input class="form-check-input" type="checkbox" checked="@(NewSetting.Value == "true")"
                                   @onchange="OnNewSettingBoolChanged" id="newSettingBool" />
                            <label class="form-check-label" for="newSettingBool">@(NewSetting.Value == "true" ? "Enabled" : "Disabled")</label>
                        </div>
                    }
                    else if (NewSetting.ValueType == "json")
                    {
                        <textarea class="form-control font-monospace" rows="3" @bind="NewSetting.Value" placeholder="{ }"></textarea>
                    }
                    else if (NewSetting.ValueType == "int")
                    {
                        <input type="number" class="form-control" @bind="NewSetting.Value" placeholder="0" />
                    }
                    else
                    {
                        <input class="form-control" @bind="NewSetting.Value" />
                    }
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Description</label>
                    <input class="form-control" @bind="NewSetting.Description" placeholder="Optional description for this setting" />
                </div>
                <div class="col-12 text-end">
                    <button class="btn btn-outline-secondary me-2" @onclick="OnCancelAdd">Cancel</button>
                    <button class="btn btn-success" @onclick="OnCreateSetting" disabled="@Host.InProgress">
                        @if (Host.InProgress)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        }
                        <i class="bi bi-plus-lg me-1"></i> Create
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (Host.InProgress && Settings == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (Settings != null)
{
    @if (GroupedSettings.Any())
    {
        @foreach (var group in GroupedSettings)
        {
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">
                        <i class="bi @GetCategoryIcon(group.Key) me-2"></i>@group.Key
                        <span class="badge bg-secondary ms-2">@group.Count()</span>
                    </h6>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:22%">Key</th>
                                <th style="width:30%">Value</th>
                                <th style="width:8%">Type</th>
                                <th style="width:28%">Description</th>
                                <th style="width:12%" class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var setting in group)
                            {
                                <tr class="@(EditingSettingId == setting.Id ? "table-active" : "")">
                                    <td>
                                        <span class="fw-semibold">@setting.Key</span>
                                        @if (setting.IsSensitive)
                                        {
                                            <i class="bi bi-shield-lock text-warning ms-1" title="Sensitive value"></i>
                                        }
                                        @if (CurrentScope == ScopeOrganization && !string.IsNullOrEmpty(setting.OrganizationName))
                                        {
                                            <br /><span class="badge bg-info text-dark mt-1">@setting.OrganizationName</span>
                                        }
                                    </td>
                                    <td>
                                        @if (EditingSettingId == setting.Id)
                                        {
                                            <div class="d-flex align-items-center gap-2">
                                                @if (setting.ValueType == "bool")
                                                {
                                                    <div class="form-check form-switch mb-0">
                                                        <input class="form-check-input" type="checkbox" checked="@IsEditingTrue()"
                                                               @onchange="OnEditBoolChanged" />
                                                        <label class="form-check-label">@(IsEditingTrue() ? "Enabled" : "Disabled")</label>
                                                    </div>
                                                }
                                                else if (setting.ValueType == "int")
                                                {
                                                    <input type="number" class="form-control form-control-sm" style="max-width: 180px;" @bind="EditingValue" />
                                                }
                                                else if (setting.ValueType == "json")
                                                {
                                                    <textarea class="form-control form-control-sm font-monospace" rows="3" @bind="EditingValue"></textarea>
                                                }
                                                else
                                                {
                                                    <input type="text" class="form-control form-control-sm" @bind="EditingValue" />
                                                }
                                            </div>
                                        }
                                        else if (setting.IsSensitive && !RevealedSettings.Contains(setting.Id))
                                        {
                                            <span class="font-monospace text-muted user-select-none">••••••••</span>
                                            <button class="btn btn-sm btn-link p-0 ms-2 text-secondary" @onclick="() => OnRevealToggle(setting)" title="Reveal value">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            @if (setting.ValueType == "bool")
                                            {
                                                @if (setting.Value == "true")
                                                {
                                                    <span class="badge bg-success"><i class="bi bi-check-lg me-1"></i>Enabled</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary"><i class="bi bi-x-lg me-1"></i>Disabled</span>
                                                }
                                            }
                                            else if (setting.ValueType == "json")
                                            {
                                                <code class="small text-break">@TruncateValue(setting.Value, 50)</code>
                                            }
                                            else if (setting.ValueType == "int")
                                            {
                                                <span class="font-monospace">@setting.Value</span>
                                            }
                                            else
                                            {
                                                <span>@setting.Value</span>
                                            }

                                            @if (setting.IsSensitive && RevealedSettings.Contains(setting.Id))
                                            {
                                                <button class="btn btn-sm btn-link p-0 ms-2 text-secondary" @onclick="() => OnRevealToggle(setting)" title="Hide value">
                                                    <i class="bi bi-eye-slash"></i>
                                                </button>
                                            }
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @GetTypeBadgeClass(setting.ValueType)">@setting.ValueType</span>
                                    </td>
                                    <td class="text-muted small">
                                        @(setting.Description ?? "\u2014")
                                    </td>
                                    <td class="text-end">
                                        @if (EditingSettingId == setting.Id)
                                        {
                                            <div class="btn-group btn-group-sm">
                                                <button class="btn btn-success" @onclick="OnSaveEdit" disabled="@Host.InProgress" title="Save">
                                                    @if (Host.InProgress)
                                                    {
                                                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-check-lg"></i>
                                                    }
                                                </button>
                                                <button class="btn btn-outline-secondary" @onclick="OnCancelEdit" title="Cancel">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="btn-group btn-group-sm">
                                                <button class="btn btn-outline-primary" @onclick="() => OnStartEdit(setting)" disabled="@Host.InProgress" title="Edit">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="btn btn-outline-danger" @onclick="() => ShowDeleteConfirmation(setting)" disabled="@Host.InProgress" title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
    else
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="bi bi-sliders text-muted" style="font-size: 3rem;"></i>
                <p class="text-muted mt-3 mb-0">
                    @if (!string.IsNullOrEmpty(SearchTerm))
                    {
                        <span>No settings match your search.</span>
                    }
                    else
                    {
                        <span>No settings found for the <strong>@CurrentScope</strong> scope.</span>
                    }
                </p>
            </div>
        </div>
    }
}

@if (SettingToDelete != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete the setting <strong>@SettingToDelete.Category.@SettingToDelete.Key</strong>?</p>
                    <p class="text-danger">This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDelete" disabled="@Host.InProgress">
                        @if (Host.InProgress)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        }
                        Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}
