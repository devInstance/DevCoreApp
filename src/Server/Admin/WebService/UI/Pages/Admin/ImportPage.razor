@page "/admin/import"
@page "/admin/import/{EntityType}"
@attribute [Authorize(Roles = "Owner,Admin")]

<PageTitle>Import Data</PageTitle>

<h4 class="mb-4">Import Data</h4>

@if (Host.IsError)
{
    <div class="alert alert-danger mb-3">
        <i class="bi bi-exclamation-triangle me-1"></i>
        @Host.ErrorMessage
    </div>
}

@* ── Step Indicator ── *@
<div class="d-flex mb-4">
    @foreach (var step in Enum.GetValues<ImportWizardStep>())
    {
        var isActive = step == CurrentStep;
        var isCompleted = step < CurrentStep;
        <div class="d-flex align-items-center @(step != ImportWizardStep.Upload ? "ms-3" : "")">
            <span class="badge @(isActive ? "bg-primary" : isCompleted ? "bg-success" : "bg-secondary") rounded-circle me-1"
                  style="width: 28px; height: 28px; line-height: 20px; text-align: center;">
                @((int)step + 1)
            </span>
            <span class="@(isActive ? "fw-bold" : "text-muted")">@GetStepLabel(step)</span>
        </div>
    }
</div>

@* ── Step 1: Upload ── *@
@if (CurrentStep == ImportWizardStep.Upload)
{
    <div class="card">
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label">Entity Type</label>
                <select class="form-select" style="max-width: 300px;" @bind="SelectedEntityType" disabled="@Host.InProgress">
                    <option value="">Select entity type...</option>
                    @if (EntityTypes != null)
                    {
                        @foreach (var type in EntityTypes)
                        {
                            <option value="@type">@type</option>
                        }
                    }
                </select>
            </div>

            @if (!string.IsNullOrEmpty(SelectedEntityType))
            {
                <div class="mb-3">
                    <label class="form-label">Download Template</label>
                    <div class="d-flex gap-2">
                        <a class="btn btn-sm btn-outline-secondary" href="api/import-export/template?entityType=@SelectedEntityType&format=Csv" target="_blank">
                            <i class="bi bi-filetype-csv me-1"></i>CSV Template
                        </a>
                        <a class="btn btn-sm btn-outline-secondary" href="api/import-export/template?entityType=@SelectedEntityType&format=Xlsx" target="_blank">
                            <i class="bi bi-file-earmark-excel me-1"></i>Excel Template
                        </a>
                    </div>
                </div>
            }

            <div class="mb-3">
                <label class="form-label">File</label>
                <InputFile class="form-control" style="max-width: 400px;" OnChange="OnFileChanged" accept=".csv,.xlsx"
                           disabled="@(Host.InProgress || string.IsNullOrEmpty(SelectedEntityType))" />
                <div class="form-text">Supported formats: CSV (.csv) and Excel (.xlsx)</div>
            </div>
            <div class="mt-3">
                <button class="btn btn-primary" @onclick="OnUpload" disabled="@(Host.InProgress || BufferedFileStream == null)">
                    @if (Host.InProgress)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    Next
                    <i class="bi bi-arrow-right ms-1"></i>
                </button>
            </div>
        </div>
    </div>
}

@* ── Step 2: Map Columns ── *@
@if (CurrentStep == ImportWizardStep.MapColumns)
{
    <div class="card">
        <div class="card-body">
            <p class="text-muted mb-3">
                Map your file columns to the target fields. Columns mapped to "Skip" will be ignored.
            </p>

            @if (UnmappedColumns.Count > 0)
            {
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle me-1"></i>
                    <strong>@UnmappedColumns.Count column(s)</strong> could not be auto-matched:
                    <strong>@string.Join(", ", UnmappedColumns)</strong>.
                    Map them manually or leave as "Skip" to ignore.
                </div>
            }

            <table class="table table-sm" style="max-width: 700px;">
                <thead>
                    <tr>
                        <th style="width: 50%;">Source Column (from file)</th>
                        <th style="width: 50%;">Target Field</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ColumnMappings != null)
                    {
                        @foreach (var mapping in ColumnMappings)
                        {
                            <tr class="@(string.IsNullOrEmpty(mapping.TargetField) ? "table-warning" : "")">
                                <td>@mapping.SourceColumnName</td>
                                <td>
                                    <select class="form-select form-select-sm" @bind="mapping.TargetField">
                                        <option value="">— Skip —</option>
                                        @if (ImportFields != null)
                                        {
                                            @foreach (var field in ImportFields)
                                            {
                                                <option value="@field.Field">
                                                    @field.Label @(field.IsRequired ? "*" : "")
                                                </option>
                                            }
                                        }
                                    </select>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
            @if (RequiresOrganization)
            {
                <div class="alert alert-warning mt-3">
                    <i class="bi bi-building me-1"></i>
                    <strong>Organization required</strong> — Your account has no default organization. Select one for this import.
                </div>
                <div class="mb-3" style="max-width: 400px;">
                    <label class="form-label">Organization</label>
                    <select class="form-select" @bind="SelectedOrganizationId">
                        <option value="">Select organization...</option>
                        @if (AvailableOrganizations != null)
                        {
                            @foreach (var org in AvailableOrganizations)
                            {
                                <option value="@org.Id">@(new string('\u00A0', org.Level * 4))@org.Name</option>
                            }
                        }
                    </select>
                </div>
            }

            <div class="mt-3">
                <button class="btn btn-primary" @onclick="OnValidate"
                        disabled="@(Host.InProgress || (RequiresOrganization && string.IsNullOrEmpty(SelectedOrganizationId)))">
                    @if (Host.InProgress)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    Validate
                </button>
                <button class="btn btn-outline-secondary ms-2" @onclick="OnBackToUpload" disabled="@Host.InProgress">Back</button>
            </div>
        </div>
    </div>
}

@* ── Step 3: Preview ── *@
@if (CurrentStep == ImportWizardStep.Preview)
{
    <div class="card mb-3">
        <div class="card-body">
            @if (ValidationResult != null)
            {
                <div class="d-flex gap-3 mb-3">
                    <span class="badge bg-info fs-6">Total: @ValidationResult.TotalRows</span>
                    <span class="badge bg-success fs-6">Valid: @ValidationResult.ValidRows</span>
                    @if (ValidationResult.WarningRows > 0)
                    {
                        <span class="badge bg-warning text-dark fs-6">Warnings: @ValidationResult.WarningRows</span>
                    }
                    <span class="badge bg-danger fs-6">Errors: @ValidationResult.ErrorRows</span>
                </div>
            }

            <div class="d-flex gap-3 mb-2">
                <span><span class="badge bg-success">New</span> Will be created</span>
                <span><span class="badge bg-warning text-dark">Update</span> Will update existing</span>
                <span><span class="badge bg-danger">Error</span> Has validation errors</span>
            </div>

            <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                <table class="table table-sm table-hover">
                    <thead class="table-light sticky-top">
                        <tr>
                            <th style="width: 40px;">
                                <input type="checkbox"
                                       class="form-check-input"
                                       checked="@(ExcludedRows.Count == 0)"
                                       @onchange="() => ToggleAllRows()" />
                            </th>
                            <th style="width: 50px;">#</th>
                            <th style="width: 80px;">Status</th>
                            @if (ImportFields != null)
                            {
                                @foreach (var field in ImportFields)
                                {
                                    <th>@field.Label</th>
                                }
                            }
                            <th>Issues</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ValidationResult?.Rows != null)
                        {
                            @foreach (var row in ValidationResult.Rows)
                            {
                                <tr class="@GetRowCssClass(row)" style="@(ExcludedRows.Contains(row.RowNumber) ? "opacity: 0.5;" : "")">
                                    <td>
                                        @if (row.Status != ImportRowStatus.Error)
                                        {
                                            <input type="checkbox"
                                                   class="form-check-input"
                                                   checked="@(!ExcludedRows.Contains(row.RowNumber))"
                                                   @onchange="() => ToggleRowExclusion(row.RowNumber)" />
                                        }
                                    </td>
                                    <td>@row.RowNumber</td>
                                    <td>
                                        @if (row.Status == ImportRowStatus.Error)
                                        {
                                            <span class="badge bg-danger">Error</span>
                                        }
                                        else if (row.Status == ImportRowStatus.Warning)
                                        {
                                            <span class="badge bg-warning text-dark">Update</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">New</span>
                                        }
                                    </td>
                                    @if (ImportFields != null)
                                    {
                                        @foreach (var field in ImportFields)
                                        {
                                            <td>@(row.Values.TryGetValue(field.Field, out var val) ? val : "")</td>
                                        }
                                    }
                                    <td class="small">
                                        @if (row.Errors.Count > 0)
                                        {
                                            <span class="text-danger">@string.Join("; ", row.Errors)</span>
                                        }
                                        @if (row.Warnings.Count > 0)
                                        {
                                            <span class="text-warning">@string.Join("; ", row.Warnings)</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div class="mt-3">
                <button class="btn btn-success" @onclick="OnCommit" disabled="@(Host.InProgress || SelectedRowCount == 0)">
                    @if (Host.InProgress)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    Import @SelectedRowCount Rows
                </button>
                <button class="btn btn-outline-secondary ms-2" @onclick="OnBackToMapping" disabled="@Host.InProgress">Back</button>
            </div>
        </div>
    </div>
}

@* ── Step 4: Result ── *@
@if (CurrentStep == ImportWizardStep.Result)
{
    <div class="card">
        <div class="card-body">
            @if (CommitResult != null && !IsBackgroundProcessing)
            {
                <div class="alert @(CommitResult.ErrorRows > 0 ? "alert-warning" : "alert-success")">
                    <h5>Import Complete</h5>
                    <ul class="mb-0">
                        <li><strong>Created:</strong> @CommitResult.ImportedRows rows</li>
                        @if (CommitResult.UpdatedRows > 0)
                        {
                            <li><strong>Updated:</strong> @CommitResult.UpdatedRows rows</li>
                        }
                        <li><strong>Skipped (validation errors):</strong> @CommitResult.SkippedRows rows</li>
                        @if (CommitResult.ErrorRows > 0)
                        {
                            <li><strong>Failed during import:</strong> @CommitResult.ErrorRows rows</li>
                        }
                    </ul>
                </div>

                @if (CommitResult.Errors.Count > 0)
                {
                    <div class="alert alert-danger">
                        <h6>Errors:</h6>
                        <ul class="mb-0 small">
                            @foreach (var error in CommitResult.Errors)
                            {
                                <li>@error</li>
                            }
                        </ul>
                    </div>
                }

                @if (CanRollback)
                {
                    @if (!ShowRollbackConfirm)
                    {
                        <button class="btn btn-outline-danger mt-2" @onclick="() => ShowRollbackConfirm = true" disabled="@Host.InProgress">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>Rollback Import
                        </button>
                    }
                    else
                    {
                        <div class="alert alert-danger mt-2">
                            <strong>Are you sure?</strong> This will delete all @(CommitResult.ImportedRows + CommitResult.UpdatedRows) imported/updated records.
                            <div class="mt-2">
                                <button class="btn btn-danger btn-sm" @onclick="OnRollback" disabled="@Host.InProgress">
                                    @if (Host.InProgress)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                    }
                                    Yes, Rollback
                                </button>
                                <button class="btn btn-outline-secondary btn-sm ms-2" @onclick="() => ShowRollbackConfirm = false" disabled="@Host.InProgress">
                                    Cancel
                                </button>
                            </div>
                        </div>
                    }
                }

                @if (IsRolledBack)
                {
                    <div class="alert alert-info mt-2">
                        <i class="bi bi-check-circle me-1"></i>Import has been rolled back successfully.
                    </div>
                }
            }
            else if (IsBackgroundProcessing)
            {
                <div class="alert alert-info">
                    <div class="d-flex align-items-center mb-2">
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        <span>@ProgressLabel</span>
                    </div>
                    <div class="progress" style="height: 20px;">
                        <div class="progress-bar progress-bar-striped progress-bar-animated"
                             role="progressbar"
                             style="width: @ProgressPercent%"
                             aria-valuenow="@ProgressPercent"
                             aria-valuemin="0"
                             aria-valuemax="100">
                            @ProgressPercent%
                        </div>
                    </div>
                    @if (CurrentSession != null && CurrentSession.ImportedRows > 0)
                    {
                        <div class="mt-2 text-muted small">
                            @CurrentSession.ImportedRows of @CurrentSession.ValidRows rows imported
                        </div>
                    }
                </div>
            }

            <div class="mt-3">
                <button class="btn btn-primary" @onclick="OnNewImport">New Import</button>
            </div>
        </div>
    </div>
}
