@page "/admin/webhooks"
@attribute [Authorize(Policy = "Admin.Webhooks.View")]

<PageTitle>Webhooks</PageTitle>

<div class="row mb-3">
    <div class="col col-md-6 col-lg-4">
        <HSearchBar @bind-Value="SearchTerm" Placeholder="Search subscriptions..." OnSearch="OnSearch" Disabled="Host.InProgress" />
    </div>
    <div class="col col-md-6 col-lg-8">
        <div class="float-end">
            <a class="btn btn-outline-secondary me-2" href="admin/webhook-deliveries">
                <i class="bi bi-list-check me-1"></i>Delivery Log
            </a>
            <AuthorizeView Policy="Admin.Webhooks.Create">
                <button class="btn btn-primary" @onclick="ShowCreateModal" disabled="@Host.InProgress">
                    <i class="bi bi-plus-lg me-1"></i>New Subscription
                </button>
            </AuthorizeView>
        </div>
    </div>
</div>

@if (Host.IsError)
{
    <div class="alert alert-danger" role="alert">
        @Host.ErrorMessage
    </div>
}

<HDataGrid TItem="DevInstance.DevCoreApp.Shared.Model.Webhooks.WebhookSubscriptionItem"
           Data="SubscriptionList"
           Columns="Columns"
           IsLoading="Host.InProgress"
           OnSort="OnSortAsync"
           OnPageChanged="OnPageChangedAsync"
           OnColumnsChanged="OnColumnsChanged"
           OnRowClick="OnRowClick">
    <ColumnTemplates>
        <HColumnTemplate TItem="DevInstance.DevCoreApp.Shared.Model.Webhooks.WebhookSubscriptionItem" Field="isactive" Context="sub">
            @if (sub.IsActive)
            {
                <span class="badge bg-success">Active</span>
            }
            else
            {
                <span class="badge bg-secondary">Inactive</span>
            }
        </HColumnTemplate>
        <HColumnTemplate TItem="DevInstance.DevCoreApp.Shared.Model.Webhooks.WebhookSubscriptionItem" Field="actions" Context="sub">
            <AuthorizeView Policy="Admin.Webhooks.Edit">
                <button class="btn btn-sm btn-outline-primary me-1" title="Edit" @onclick="() => ShowEditModalAsync(sub)" @onclick:stopPropagation="true">
                    <i class="bi bi-pencil"></i>
                </button>
            </AuthorizeView>
            <AuthorizeView Policy="Admin.Webhooks.Delete">
                <button class="btn btn-sm btn-outline-danger" title="Delete" @onclick="() => ShowDeleteConfirmation(sub)" @onclick:stopPropagation="true">
                    <i class="bi bi-trash"></i>
                </button>
            </AuthorizeView>
        </HColumnTemplate>
    </ColumnTemplates>
    <EmptyContent>
        <p>No webhook subscriptions found.</p>
    </EmptyContent>
    <SearchContent>
        <div class="alert alert-light">
            Searching for <strong>@context</strong>
            <button type="button" class="btn-close ms-2" @onclick="OnClearSearch"></button>
        </div>
    </SearchContent>
</HDataGrid>

<GridSettings Columns="Columns" OnSave="OnSave" PageSize="pageCount" TItem="DevInstance.DevCoreApp.Shared.Model.Webhooks.WebhookSubscriptionItem" />

@* ---------- Create/Edit Modal ---------- *@
@if (showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <EditForm Model="EditItem" OnValidSubmit="OnSaveSubscription">
                    <DataAnnotationsValidator />
                    <div class="modal-header">
                        <h5 class="modal-title">@(isEditMode ? "Edit Subscription" : "New Subscription")</h5>
                        <button type="button" class="btn-close" @onclick="CloseModal"></button>
                    </div>
                    <div class="modal-body">
                        <ValidationSummary class="text-danger" role="alert" />
                        <div class="mb-3">
                            <label for="EditItem.EventType" class="form-label">Event Type</label>
                            <InputSelect @bind-Value="EditItem.EventType" id="EditItem.EventType" class="form-select">
                                <option value="">-- Select Event Type --</option>
                                @foreach (var evt in DevInstance.DevCoreApp.Shared.Model.Webhooks.WebhookEventTypes.All)
                                {
                                    <option value="@evt">@evt</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => EditItem.EventType" class="text-danger" />
                        </div>
                        <div class="form-floating mb-3">
                            <InputText @bind-Value="EditItem.Url" id="EditItem.Url" class="form-control" placeholder="https://..." />
                            <label for="EditItem.Url">URL</label>
                            <ValidationMessage For="() => EditItem.Url" class="text-danger" />
                        </div>
                        <div class="form-floating mb-3">
                            <InputText @bind-Value="EditItem.OrganizationId" id="EditItem.OrganizationId" class="form-control" placeholder="Organization PublicId" />
                            <label for="EditItem.OrganizationId">Organization PublicId (optional)</label>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(EditItem.OrganizationName))
                        {
                            <div class="form-text mb-3">Resolved organization: @EditItem.OrganizationName</div>
                        }
                        <div class="form-check form-switch mb-3">
                            <InputCheckbox @bind-Value="EditItem.IsActive" id="EditItem.IsActive" class="form-check-input" />
                            <label for="EditItem.IsActive" class="form-check-label">Active</label>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(EditItem.Secret))
                        {
                            @if (showSecretNotice)
                            {
                                <div class="alert alert-warning" role="alert">
                                    Save this signing secret now. It is required for webhook signature verification.
                                </div>
                            }
                            <div class="form-floating mb-3">
                                <InputText @bind-Value="EditItem.Secret" id="EditItem.Secret" class="form-control font-monospace" readonly />
                                <label for="EditItem.Secret">Signing Secret</label>
                            </div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseModal">@(showSecretNotice ? "Close" : "Cancel")</button>
                        <button type="submit" class="btn btn-primary" disabled="@Host.InProgress">
                            @if (Host.InProgress)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                            }
                            @(showSecretNotice ? "Save Changes" : isEditMode ? "Save Changes" : "Create")
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@* ---------- Delete Confirmation Modal ---------- *@
@if (DeletingSub != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete the webhook subscription for <strong>@DeletingSub.EventType</strong> to <strong>@DeletingSub.Url</strong>?</p>
                    <p class="text-danger">This will also delete all associated delivery logs.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDelete" disabled="@Host.InProgress">
                        @if (Host.InProgress)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        }
                        Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}
