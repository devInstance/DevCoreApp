<div class="h-search-bar" style="position: relative;">
    <div class="input-group bg-light rounded-3 border">
        <span class="input-group-text bg-transparent border-0" role="button" @onclick="HandleSearchClick">
            <i class="bi bi-search text-muted"></i>
        </span>
        <input type="text"
               class="form-control bg-transparent border-0 shadow-none"
               placeholder="@Placeholder"
               value="@Value"
               @oninput="HandleInput"
               @onkeydown="HandleKeyDown"
               disabled="@Disabled" />
        @if (AdvancedContent != null)
        {
            <button class="btn bg-transparent border-0 @(_isOpen ? "text-primary" : "text-muted")"
                    type="button"
                    @onclick="ToggleDropdown"
                    disabled="@Disabled">
                <i class="bi bi-sliders"></i>
            </button>
        }
    </div>

    @if (_isOpen && AdvancedContent != null)
    {
        <div class="h-search-bar-backdrop" @onclick="CloseDropdown"></div>
        <div class="h-search-bar-dropdown shadow-lg rounded-3 bg-white border p-3">
            @AdvancedContent
            <div class="d-flex justify-content-end mt-3">
                <button class="btn btn-primary btn-sm" type="button" @onclick="HandleDropdownSearch">
                    <i class="bi bi-search me-1"></i>Search
                </button>
            </div>
        </div>
    }
</div>
