{
  "DetailedErrors": true,
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Debug",
      "Microsoft.Hosting.Lifetime": "Debug",
      "Microsoft.AspNetCore.SignalR": "Debug"
    }
  },
  "BackgroundTasks": {
    "MaxConcurrency": 4,
    "PollingIntervalSeconds": 5,
    "BaseRetryDelaySeconds": 5,
    "MaxRetryDelaySeconds": 300,
    "BatchSize": 10,
    "RunningTaskTimeoutMinutes": 15,
    "RecoverySweepIntervalSeconds": 30
  }
}
